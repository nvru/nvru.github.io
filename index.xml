      <description>&lt;p&gt;&lt;img src=&#34;https://nvru.github.io/images/bonjur/vm.png&#34; alt=&#34;VM&#34;&gt;&lt;/p&gt;
&lt;h2 id=&#34;target-information&#34;&gt;Target Information&lt;/h2&gt;
&lt;table&gt;
	&lt;thead&gt;
			&lt;tr&gt;
					&lt;th&gt;Role&lt;/th&gt;
					&lt;th&gt;IP Address&lt;/th&gt;
			&lt;/tr&gt;
	&lt;/thead&gt;
	&lt;tbody&gt;
			&lt;tr&gt;
					&lt;td&gt;Attacker&lt;/td&gt;
					&lt;td&gt;&lt;code&gt;10.10.10.2&lt;/code&gt;&lt;/td&gt;
			&lt;/tr&gt;
			&lt;tr&gt;
